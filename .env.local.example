# Supabase — get from https://supabase.com/dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Resend — get from https://resend.com/api-keys
RESEND_API_KEY=re_YOUR_KEY_HERE

# Division URLs (update for production)
NEXT_PUBLIC_EXHIBITION_URL=http://localhost:3001
NEXT_PUBLIC_AUTOMATION_URL=http://localhost:3002
NEXT_PUBLIC_LEADS_URL=http://localhost:3003
NEXT_PUBLIC_LAB_URL=http://localhost:3004

# Site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
